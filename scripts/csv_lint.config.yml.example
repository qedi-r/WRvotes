
# Format is: filename: folder relative to targetdir 
# Assume every source ends with .csv

sources:
  'nominees': 
    folder: sync
    key: UniqueID
  'events': 
    folder: sync
    key: RowID
  'media': 
    folder: sync
    key: URL
  'position-tags': 
    folder: internal
    key: PositionUniqueName
  'media-categories': 
    folder: internal
    key: CategoryName
  'aliases': 
    folder: internal
    key: Alias

# The root of the git config file
gitdir: /home/pnijjar/src/wrvotes

# The path to the CSV files, relative to GITDIR
targetdir: docs/_data

# Used for parsing dates
timezone: 'America/Toronto'

# Assorted debugging parameters. 
# Higher thresholds are more verbose.
debug:
  screen:
    enable: true
    threshold: 0
  log: 
    enable: true
    logfile: /tmp/csv-lint.log
    threshold: 1
  default:
    level: 3
  errors:
    level: 1

